int GNSS_GetPosition(char *buffer, int max_len) {
    // Simulazione di posizione GPS
    const char *pos = "Lat:45.123456, Lon:9.654321";

    if (strlen(pos) + 1 > (unsigned)max_len) {
        return -1;  // buffer troppo piccolo
    }
    strcpy(buffer, pos);
    return 0;  // successo
}
